  "trigger_sensitivity": {
    "description": "Triggers (L2/R2) provide analog input 0.0-1.0. Skills bound to triggers can scale their effect by the input value.",
    "example": "If camera_rotate_right is bound to a trigger: rotation_speed = base_speed × trigger_value. Light press = slow rotation, full press = fast rotation.",
    "deadzone": 0.1,
    "curve": "linear",
    "note": "In the current implementation, triggers are buttons (digital). Analog support is a future enhancement. The RuleBook defines the full spec; the engine implements what it can."
  }
