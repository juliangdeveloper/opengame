[gd_resource type="Resource" script_class="SkillResource" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/skill/skill_resource.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"hit_projectile"
name = "Golpe Proyectil"
description = "Golpe frontal con movimiento. Spawna un cubo trigger que viaja en la dirección de la cámara durante 2 segundos a 1 m/s."
flavor_text = "La fuerza bruta, ahora con propósito — viaja hacia donde miras."
category = &"combat"
type = &"combat"
target_resolver = {
"kind": "area",
"params": {
"note": "Target = whoever activates the trigger (enters the hitbox). Not the caster."
}
}
atoms = [{
"type": "hit",
"params": {
"asset": "res://assets/hitbox_cube.tscn",
"offset": {
"forward": 1.0,
"right": 0.0,
"up": 0.0
},
"dimensions": {
"x": 0.5,
"y": 0.5,
"z": 0.5
},
"duration": 2.0,
"spawn_time": 2.0,
"movement": {
"direction": "camera",
"speed": 1.0
},
"push_force": 1.0,
"base_damage": 2.0
}
}]
costs = {
"stamina": 10.0,
"cooldown": 0.4
}
