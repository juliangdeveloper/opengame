"type": "spawn",
"params": {
"asset": "res://assets/hitbox_cube.tscn",
"offset": {
"forward": 1.0,
"right": 0.0,
"up": 0.0
},
"dimensions": {
"x": 0.5,
"y": 0.5,
"z": 0.5
},
"duration": 0.5
}
}, {
"type": "push",
"params": {
"force": 1.0,
"weight_multiplier": true
}
}, {
"type": "damage",
"params": {
"amount": 2.0,
"damage_type": "physical",
"element": "physical"
}
}]
skill_flow = ["spawn", ["push", "damage"]]
costs = {
"stamina": 10.0,
"cooldown": 0.4
}
