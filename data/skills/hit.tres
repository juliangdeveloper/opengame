[ext_resource type="Script" path="res://scripts/skill/skill_resource.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"hit"
name = "Golpear"
description = "Golpe frontal. Spawna un cubo trigger que empuja y daña todo lo que toque."
flavor_text = "La fuerza bruta, canalizada a través de la voluntad."
category = &"combat"
type = &"combat"
target_resolver = {
"kind": "area",
"params": {
"note": "Target = whoever activates the trigger (enters the hitbox). Not the caster."
}
}
